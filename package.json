{
  "name": "pnex",
  "version": "1.0.2",
  "description": "A simple yet robust terminal app with AI inline chat",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "node scripts/build-renderer.js",
    "build:css": "npx @tailwindcss/cli -i ./src/renderer/styles/input.css -o ./dist/renderer/styles/output.css --minify",
    "build:static": "node scripts/copy-static.js",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer && npm run build:css && npm run build:static",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "build:preload": "node scripts/build-preload.js"
  },
  "keywords": [
    "terminal",
    "electron",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.pnex.app",
    "productName": "Pnex",
    "executableName": "pnex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "openai": "^6.33.0",
    "electron": "^41.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
